# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="mongodb://localhost:27017/specter_dev"

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# The public base URL of this API (used for snippet generation and Swagger)
API_BASE_URL="http://localhost:4000"

# The public URL of the front-end app (used for Stripe redirect URLs)
APP_URL="http://localhost:3000"

# Origins allowed by CORS (comma-separated)
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173"

# ── Auth ──────────────────────────────────────────────────────────────────────
# Must be a long random secret in production — e.g.: openssl rand -hex 64
JWT_SECRET="change_me_to_a_long_random_secret"

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Stripe Price IDs — create these in your Stripe dashboard
STRIPE_PRICE_STARTER_MONTHLY="price_..."
STRIPE_PRICE_STARTER_ANNUAL="price_..."
STRIPE_PRICE_PRO_MONTHLY="price_..."
STRIPE_PRICE_PRO_ANNUAL="price_..."
STRIPE_PRICE_AGENCY_MONTHLY="price_..."
STRIPE_PRICE_AGENCY_ANNUAL="price_..."

# ── Edge Worker ───────────────────────────────────────────────────────────────
# Base URL of the Cloudflare Worker / edge function that evaluates kill state
EDGE_WORKER_URL="http://localhost:8787"
# Shared secret for internal API calls between this API and the edge worker
EDGE_INTERNAL_SECRET="change_me"

# ── Internal ──────────────────────────────────────────────────────────────────
# Secret header required on the POST /keys/verify endpoint (called by edge worker)
INTERNAL_API_SECRET="change_me"
